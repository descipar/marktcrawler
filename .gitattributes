# Normalize line endings: store as LF in the repo, checkout as-is on Windows
* text=auto
*.py text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf

# Binaries
*.db binary
*.png binary
*.jpg binary
*.ico binary
